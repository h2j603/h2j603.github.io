# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The same variables must be set as repository secrets for the GitHub Actions
# deploy workflow (.github/workflows/deploy.yml).
# ---------------------------------------------------------------------------

# Are.na v3 API token.
# Needs WRITE scope to run `npm run setup:arena` (it creates channels/metadata).
# A read-only token is enough for `npm run build` once the structure exists.
ARENA_TOKEN=

# Slug of the index channel that lists every work channel.
# `npm run setup:arena` will create this channel if it does not exist and print
# back the real slug Are.na assigned.
ARENA_INDEX_CHANNEL=works

# Google service account credentials used to read each work's body Doc.
# Either an absolute/relative path to the JSON key file, OR the raw JSON, OR a
# base64-encoded blob of the JSON (handy for CI secrets).
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json

# ---- Optional overrides (sensible defaults shown) --------------------------
# ARENA_API_BASE=https://api.are.na/v3
# ARENA_AUTH_SCHEME=Bearer
