---
// hyuk repo의 디자인을 원본 그대로 복제 — Typekit 폰트 + 한글 woff2 포함.
import '../styles/global.css';
// 모바일 전용 — 모든 룰이 @media (max-width: 600px) 안에 격리. 데스크탑 영향 0.
import '../styles/mobile.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    {/* 검색·공유 메타 — SSG라 빌드 타임에 대표값 1세트. 파비콘은 줄무늬 모티프 SVG. */}
    <meta
      name="description"
      content="그래픽 디자이너 장혁(Hyuk Jang)의 포트폴리오 — 작업, 메모, 수집한 링크. Built from Are.na."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#fbfaff" />
    {/* Open Graph / Twitter — 카톡·트위터·디스코드 등 링크 공유 미리보기 */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="hyuk.xyz" />
    <meta property="og:title" content="Hyuk Jang (장혁) — Graphic Designer" />
    <meta
      property="og:description"
      content="Selected works, notes, and a collection of links. Built from Are.na."
    />
    <meta property="og:url" content="https://hyuk.xyz/" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Hyuk Jang (장혁) — Graphic Designer" />
    <meta
      name="twitter:description"
      content="Selected works, notes, and a collection of links. Built from Are.na."
    />

    {/* 컬러 팔레트 — 1분마다 다음 색으로 순환(셋: original/blue/gold).
        여기선 첫 페인트 전 초기값만 박고(깜빡임 방지), 분 경계마다 갱신은
        palette.js가 라이브로 한다. */}
    <script is:inline>
      (function () {
        var p = ['original', 'blue', 'gold'];
        document.documentElement.dataset.palette = p[Math.floor(Date.now() / 60000) % p.length];
      })();
    </script>

    {/* rel=me — IndieAuth/RelMeAuth 신원 확인용. 인디웹 웹링(indielogin.com)이
        이 링크로 GitHub 프로필 ↔ 사이트 양방향을 검증한다.
        (GitHub 프로필 "Website" 칸이 hyuk.xyz를 가리켜야 양방향 성립) */}
    <link rel="me" href="https://github.com/h2j603" />

    {/* 외부 리소스 연결 미리 열기 — 폰트(Typekit)·iframe(h2j603.github.io) 로딩 단축 */}
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="preconnect" href="https://p.typekit.net" crossorigin />
    <link rel="dns-prefetch" href="https://h2j603.github.io" />

    {/* 한글 = Heitz Wide (self-hosted). 본문 한글 폰트라 preload로 첫 페인트 단축 */}
    <link rel="preload" href="/fonts/HeitzWide-Regular.woff2" as="font" type="font/woff2" crossorigin />

    {/* Typekit — neue-haas-unica (라틴 폴백). t26-carbon은 폐기(미사용) */}
    <link rel="stylesheet" href="https://use.typekit.net/rhy6are.css" />

    {/* Typekit JS loader (원본과 동일 — wf-loading 등 lifecycle 관리) */}
    <script is:inline>
      (function (d) {
        var config = { kitId: 'fpx8ely', scriptTimeout: 3000, async: true },
          h = d.documentElement,
          t = setTimeout(function () {
            h.className = h.className.replace(/\bwf-loading\b/g, '') + ' wf-inactive';
          }, config.scriptTimeout),
          tk = d.createElement('script'),
          f = false,
          s = d.getElementsByTagName('script')[0],
          a;
        h.className += ' wf-loading';
        tk.src = 'https://use.typekit.net/' + config.kitId + '.js';
        tk.async = true;
        tk.onload = tk.onreadystatechange = function () {
          a = this.readyState;
          if (f || (a && a != 'complete' && a != 'loaded')) return;
          f = true;
          clearTimeout(t);
          try {
            // eslint-disable-next-line no-undef
            Typekit.load(config);
          } catch (e) {}
        };
        s.parentNode.insertBefore(tk, s);
      })(document);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
