---
// hyuk repo의 디자인을 원본 그대로 복제 — Typekit 폰트 + 한글 woff2 포함.
import '../styles/global.css';
// 모바일 전용 — 모든 룰이 @media (max-width: 600px) 안에 격리. 데스크탑 영향 0.
import '../styles/mobile.css';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'hyuk — graphic design works: identity, editorial, poster, type, web.',
} = Astro.props;
const SITE = 'https://hyuk.xyz';
const canonical = SITE + Astro.url.pathname;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    {/* user-scalable=no는 저시력 사용자의 핀치 줌을 막아 접근성 위반 — 쓰지 않는다 */}
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* 링크 공유 카드 (카톡·트위터·슬랙 등) — og.png는 scripts/make-og.mjs로 재생성 */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="hyuk.xyz" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE}/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    {/* 외부 리소스 연결 미리 열기 — 폰트(Typekit·jsdelivr)·iframe(h2j603.github.io) 로딩 단축 */}
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="preconnect" href="https://p.typekit.net" crossorigin />
    <link rel="preconnect" href="https://fastly.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://h2j603.github.io" />

    {/* Typekit — neue-haas-unica (body), t26-carbon (h2) */}
    <link rel="stylesheet" href="https://use.typekit.net/rhy6are.css" />

    {/* Typekit JS loader (원본과 동일 — wf-loading 등 lifecycle 관리) */}
    <script is:inline>
      (function (d) {
        var config = { kitId: 'fpx8ely', scriptTimeout: 3000, async: true },
          h = d.documentElement,
          t = setTimeout(function () {
            h.className = h.className.replace(/\bwf-loading\b/g, '') + ' wf-inactive';
          }, config.scriptTimeout),
          tk = d.createElement('script'),
          f = false,
          s = d.getElementsByTagName('script')[0],
          a;
        h.className += ' wf-loading';
        tk.src = 'https://use.typekit.net/' + config.kitId + '.js';
        tk.async = true;
        tk.onload = tk.onreadystatechange = function () {
          a = this.readyState;
          if (f || (a && a != 'complete' && a != 'loaded')) return;
          f = true;
          clearTimeout(t);
          try {
            // eslint-disable-next-line no-undef
            Typekit.load(config);
          } catch (e) {}
        };
        s.parentNode.insertBefore(tk, s);
      })(document);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
