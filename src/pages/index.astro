---
// 인덱스 — 3-col split:
//   left   : 인트로 + 푸터
//   center : 작품 표 + 아코디언 (행 클릭 시 그 아래로 카드 펼침)
//   right  : 비움 (새 컨텐츠 예정)
import fs from 'node:fs';
import path from 'node:path';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { getWorks, resolveImage, getIntro, getFooter, groupBilingual } from '../lib/site-data.js';
import { TAGS } from '../lib/schema.js';

const works = getWorks().slice().sort((a, b) => {
  // 표 기본 정렬과 동일하게 — year desc (최신 위)
  const ya = parseInt(a.year || '0', 10) || 0;
  const yb = parseInt(b.year || '0', 10) || 0;
  return yb - ya;
});
const usedTags = TAGS.filter((t) => works.some((w) => w.tags.includes(t)));

function orderedTagsOf(w: (typeof works)[number]): string[] {
  // 태그 전부 표시 — non-web 먼저, web은 맨 뒤. (표 카테고리 칸)
  const nonWeb = w.tags.filter((x) => x !== 'web');
  return w.tags.includes('web') ? [...nonWeb, 'web'] : nonWeb;
}

const introGroups = getIntro();
const footerGroups = getFooter();

// 작품 선택 안 한 기본 화면용 모자이크 (stripe-mosaic 도구로 만든 단일 SVG → 셀 그리드)
const defaultMosaic = fs.readFileSync(
  path.join(process.cwd(), 'src/data/default-mosaic.html'),
  'utf-8',
);
---

<Base title="hyuk.xyz">
  <div class="stripe-top" aria-hidden="true">
    <div class="stripe-row"></div>
    <div class="stripe-row"></div>
    <div class="stripe-row"></div>
  </div>
  {/* 세로 구분선 상단부 — stripe 구간(0~84px)을 띠 위(z200)로 지난다. */}
  <div class="col-divider-top d1" aria-hidden="true"></div>
  <div class="col-divider-top d2" aria-hidden="true"></div>
  <div class="col-divider-top d3" aria-hidden="true"></div>
  <div class="col-divider-top d4" aria-hidden="true"></div>
  <div class="col-divider-top d5" aria-hidden="true"></div>
  <div class="three-col">
    {/* 세로 구분선 하단부 — center 구간. 표/텍스트 위, 작품 이미지/iframe 아래.
        d1/d2: 3구역 경계, d3/d4: 표 컬럼(제목|연도|분류) 기준선 */}
    <div class="col-divider d1" aria-hidden="true"></div>
    <div class="col-divider d2" aria-hidden="true"></div>
    <div class="col-divider d3" aria-hidden="true"></div>
    <div class="col-divider d4" aria-hidden="true"></div>
    <div class="col-divider d5" aria-hidden="true"></div>

    {/* ──────────── 좌측: 인트로 ──────────── */}
    <div class="third left">
      <div class="content intro">
        {introGroups.length > 0 && (
          <div class="intro-body">
            {
              introGroups.map((g, i) => (
                <>
                  {i > 0 && <hr />}
                  {g.ko && g.en ? (
                    <div class="bilingual">
                      <div class="ko-body" lang="ko" set:html={g.ko} />
                      <div class="en-body" lang="en" set:html={g.en} />
                    </div>
                  ) : g.ko ? (
                    <div lang="ko" set:html={g.ko} />
                  ) : (
                    <div lang="en" set:html={g.en} />
                  )}
                </>
              ))
            }
          </div>
        )}

        {footerGroups.length > 0 && (
          <>
            <hr />
            <footer>
              {
                footerGroups.map((g, i) => (
                  <>
                    {i > 0 && <hr />}
                    {g.ko && g.en ? (
                      <div class="bilingual">
                        <div class="ko-body" lang="ko" set:html={g.ko} />
                        <div class="en-body" lang="en" set:html={g.en} />
                      </div>
                    ) : g.ko ? (
                      <div lang="ko" set:html={g.ko} />
                    ) : (
                      <div lang="en" set:html={g.en} />
                    )}
                  </>
                ))
              }
            </footer>
          </>
        )}
      </div>
    </div>

    {/* ──────────── 중앙: 작품 표 + 카드 아코디언 ──────────── */}
    <div class="third center">
      <div class="content">
        {/* 작품 미선택 시 배경 모자이크 — fixed 오버레이, 로드 시 자동 낙하 */}
        <div class="default-state" id="__default" hidden>
          <Fragment set:html={defaultMosaic} />
        </div>
        {/* 작품 표 — 행 클릭 시 바로 아래로 카드(이미지+본문) 아코디언 펼침.
            table-head(컨트롤+hr)는 스크롤 시 통째로 상단 고정 */}
        <div class="table-head">
          <div class="table-controls">
            <button type="button" class="sort-toggle" data-order="desc">↓</button>
            {usedTags.length > 0 && (
              <nav class="card-filter" aria-label="Filter by tag">
                <a href="#" class="filter-link" data-filter="all" data-active="true">All</a>
                {usedTags.map((t) => (
                  <a href="#" class="filter-link" data-filter={t} data-active="false">{t}</a>
                ))}
              </nav>
            )}
            <button type="button" class="lang-toggle" data-lang="en">KO</button>
            <button type="button" class="theme-toggle" aria-label="라이트/다크 테마 전환">☾</button>
          </div>
          <hr class="table-head-hr" />
        </div>

        {works.length > 0 ? (
          <table class="sontable">
            <colgroup>
              <col class="col-num" />
              <col class="col-year" />
              <col class="col-title" />
              <col class="col-cat" />
            </colgroup>
            <tbody>
              {works.map((w, i) => (
                <tr data-slug={w.slug} data-tags={w.tags.join(' ')}>
                  {/* 카탈로그 번호 — 기본 정렬(연도 내림차순) 기준 고정. 정렬해도 행 따라 이동 */}
                  <td class="num-cell"><span class="num-badge">{i + 1}</span></td>
                  <td>{w.year || '—'}</td>
                  <td>
                    <a href={`#${w.slug}`} data-ko={w.title || w.slug} data-en={w.titleEn || w.title || w.slug}>
                      {w.title || w.slug}
                    </a>
                  </td>
                  <td class="cat-cell">
                    {orderedTagsOf(w).length
                      ? orderedTagsOf(w).map((t) => (
                          <span class="cat-tag" data-tag={t}>{t}</span>
                        ))
                      : '—'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p>아직 작품이 없습니다.</p>
        )}

        {
          works.map((w) => {
            const cover = w.cover ? resolveImage(w.cover) : undefined;
            const externalUrl = w.links[0]?.url;
            const isWeb = w.tags.includes('web');
            return (
              <article class="work-card" id={w.slug} data-tags={w.tags.join(' ')} data-year={w.year}>
                <h2 class="card-title">
                  {w.titleEn && w.titleEn !== w.title && (
                    <span class="card-title-en" lang="en">{w.titleEn}</span>
                  )}
                  <span class="card-title-ko" lang="ko">{w.title || w.slug}</span>
                </h2>
                <p class="card-meta">
                  {w.year}
                  {w.tags.length > 0 && <> · {w.tags.join(' · ')}</>}
                </p>

                {isWeb && externalUrl ? (
                  <div class="iframe-wrap">
                    <iframe
                      src={externalUrl}
                      class="embedded-iframe"
                      title={w.title || w.slug}
                      loading="lazy"
                      allowfullscreen
                    ></iframe>
                  </div>
                ) : w.images.length > 0 ? (
                  <div class="card-images">
                    {(() => {
                      // imageLayout이 있으면 [cols, cols, ...] 그룹별로 grid row 생성.
                      // 없거나 합 불일치면 그냥 stack (한 줄에 한 장).
                      const layout =
                        w.imageLayout && w.imageLayout.length > 0
                          ? w.imageLayout
                          : w.images.map(() => 1);
                      const rows: { cols: number; imgs: typeof w.images }[] = [];
                      let i = 0;
                      for (const cols of layout) {
                        rows.push({ cols, imgs: w.images.slice(i, i + cols) });
                        i += cols;
                      }
                      return rows.map((row) => (
                        <div
                          class="image-row"
                          style={`grid-template-columns: repeat(${row.cols}, 1fr)`}
                        >
                          {row.imgs.map((img) => {
                            const asset = resolveImage(img.localPath);
                            return asset ? (
                              <Image
                                src={asset}
                                alt={img.alt || w.title || w.slug}
                                widths={[420, 640, 960]}
                                sizes={row.cols === 1 ? '40vw' : `${40 / row.cols}vw`}
                              />
                            ) : null;
                          })}
                        </div>
                      ));
                    })()}
                  </div>
                ) : cover ? (
                  <Image src={cover} alt={w.title || w.slug} widths={[420, 640, 960]} sizes="40vw" />
                ) : null}

                {w.bodyBlocks.some((b) => b.lang !== null && b.html) && (
                  <div class="card-body">
                    {
                      groupBilingual(w.bodyBlocks.filter((b) => b.lang !== null)).map((g) => (
                        g.ko && g.en ? (
                          <div class="bilingual">
                            <div lang="ko" set:html={g.ko} />
                            <div lang="en" set:html={g.en} />
                          </div>
                        ) : g.ko ? (
                          <div lang="ko" set:html={g.ko} />
                        ) : (
                          <div lang="en" set:html={g.en} />
                        )
                      ))
                    }
                  </div>
                )}
                {/* 규격 — ko/en 마커 없는 텍스트(lang null) → 연도 칸에 정렬 */}
                {w.bodyBlocks.filter((b) => b.lang === null && b.html).map((b) => (
                  <div class="card-spec" set:html={b.html} />
                ))}

                {externalUrl && (
                  <p class="card-link-wrap">
                    <a href={externalUrl} target="_blank" rel="noopener" class="card-link">
                      {w.title || w.slug}
                    </a>
                  </p>
                )}
                {/* 각주 데이터 — lang별 숨김. JS가 펼침 시 현재 언어 것을 .right로 복제 */}
                {w.bodyBlocks.map((b) =>
                  b.footnotes.length > 0 ? (
                    <ol class="fn-data" data-lang={b.lang ?? ''} hidden>
                      {b.footnotes.map((f) => (
                        <li class="fn-item" data-fn={f.id}>
                          <span class="fn-num">{f.id}</span>
                          <span class="fn-text" set:html={f.html} />
                        </li>
                      ))}
                    </ol>
                  ) : null,
                )}
              </article>
            );
          })
        }

      </div>
    </div>

    {/* ──────────── 우측: 각주 패널 ──────────── */}
    <div class="third right">
      <div class="content">
        <div class="fn-panel" id="__fnpanel" hidden>
          <ol class="fn-panel-list"></ol>
        </div>
      </div>
    </div>

  </div>

  {/* 각주 연결선 — 펼친 작품 본문 마커 ■ ↔ 우측 각주 ■ 보라선 (JS가 그림) */}
  <svg class="fn-links" aria-hidden="true"></svg>

  <script is:inline>
    // (1) 좌측 태그 필터 → 우측 표 행만 토글
    // (2) hash 변경 → 가운데에 해당 카드 한 개만 표시 + 활성 행 표시
    (function () {
      var filter = document.querySelector('.card-filter');
      var cards = Array.from(document.querySelectorAll('.work-card'));
      var rows = Array.from(document.querySelectorAll('tr[data-slug]'));
      var center = document.querySelector('.three-col .center');
      var defaultEl = document.getElementById('__default');

      // ── 표 아코디언 (데스크탑·모바일 공통) ──────────────────────────
      // 표가 메인. 행 클릭 시 해당 .work-card를 그 행 바로 아래 detail
      // 행(<td colspan=3>)으로 이동해 펼친다. 카드는 평소 .center(숨김 저장소)에
      // 있다가 이동되므로 콘텐츠 중복이 없다.
      var centerContent = document.querySelector('.three-col .center .content');
      var accSlug = null; // 현재 열린 slug
      var accRow = null;  // 현재 detail <tr>

      // 각주 패널 — 펼친 작품의 현재 언어 각주를 .right(fn-panel)에 렌더
      var fnPanel = document.getElementById('__fnpanel');
      var fnList = fnPanel ? fnPanel.querySelector('.fn-panel-list') : null;
      // 모든 작품의 각주를 항상 .right에 표시 (펼침 무관). 마커 클릭 시 해당 작품·번호로 스크롤.
      function renderFootnotes() {
        if (!fnPanel || !fnList) return;
        fnList.innerHTML = '';
        var tc = document.querySelector('.three-col');
        var lang = (tc && tc.getAttribute('data-lang')) || 'ko';
        var any = false;
        cards.forEach(function (card) {
          var data = card.querySelector('.fn-data[data-lang="' + lang + '"]')
            || card.querySelector('.fn-data');
          var items = data ? data.querySelectorAll('.fn-item') : [];
          items.forEach(function (it) {
            var clone = it.cloneNode(true);
            clone.id = 'fn-' + card.id + '-' + it.getAttribute('data-fn'); // 작품+번호 고유 id
            fnList.appendChild(clone);
            any = true;
          });
        });
        fnPanel.hidden = !any;
      }

      // 각주 연결선 — 펼친 작품 본문 마커 ■ ↔ 우측 각주 ■ 보라선
      var fnLinks = document.querySelector('.fn-links');
      function drawLinks() {
        if (!fnLinks) return;
        fnLinks.innerHTML = '';
        if (!accSlug || !accRow || !fnList) return;
        var detailCard = accRow.querySelector('.work-card');
        if (!detailCard) return;
        var SVGNS = 'http://www.w3.org/2000/svg';
        detailCard.querySelectorAll('.fn-ref').forEach(function (m) {
          var a = m.getBoundingClientRect();
          if (!a.width || !a.height) return; // 숨긴 언어(display:none)의 마커 skip — 천장(0,0) 선 방지
          var fn = m.getAttribute('data-fn');
          var tgt = fnList.querySelector('[id="fn-' + accSlug + '-' + fn + '"]');
          if (!tgt) return;
          var ftEl = tgt.querySelector('.fn-text') || tgt;
          var b = ftEl.getBoundingClientRect();
          var line = document.createElementNS(SVGNS, 'line');
          line.setAttribute('x1', (a.left + a.width / 2).toFixed(1));
          line.setAttribute('y1', (a.top + a.height / 2).toFixed(1));
          line.setAttribute('x2', (b.left + b.width / 2).toFixed(1));   // 각주 텍스트 가운데
          line.setAttribute('y2', (b.top - 18).toFixed(1));             // 각주 텍스트 위 (안착 번호 box)
          fnLinks.appendChild(line);
        });
      }

      // 모자이크 셀 N개(각주 수만큼)를 낙하 대신 각주 ■ 위치로 날아가 안착시킨다.
      function settleFootnoteCells() {
        if (!defaultEl || defaultEl.hidden || !fnList) return; // 모자이크 숨김 상태면 좌표 부정확 → skip
        var items = fnList.querySelectorAll('.fn-item');
        var cells = defaultEl.querySelectorAll('.stripe-mosaic > div');
        if (!cells.length) return;
        items.forEach(function (item, i) {
          // 이 각주(i)에 이미 안착한 셀이 있으면 재사용(언어 전환 시 위치만 갱신), 없으면 새로 선택
          var cell = defaultEl.querySelector('.stripe-mosaic > div[data-fn-index="' + i + '"]');
          var first = !cell;
          if (first) {
            cell = cells[(i * 7) % cells.length];
            if (!cell || cell.dataset.footnote) return;
            cell.style.animation = 'none';   // 낙하 취소
            cell.style.transform = '';
            cell.style.width = '16px';       // 번호 box 크기
            cell.style.height = '16px';
            var o = cell.getBoundingClientRect(); // 원위치 저장(transform 기준점)
            cell.dataset.ox = (o.left + o.width / 2).toFixed(1);
            cell.dataset.oy = (o.top + o.height / 2).toFixed(1);
            cell.style.background = 'var(--accent)';
            cell.style.zIndex = '60';
            cell.dataset.footnote = '1';
            cell.dataset.fnIndex = String(i);
            // 보라 box에 흰 번호로 모핑 (안착 위치 그대로)
            cell.textContent = String(i + 1);
            cell.style.display = 'flex';
            cell.style.alignItems = 'center';
            cell.style.justifyContent = 'center';
            cell.style.color = '#fff';
            cell.style.fontSize = '10px';
            cell.style.fontWeight = '700';
            cell.style.lineHeight = '1';
          }
          var ft = item.querySelector('.fn-text') || item;
          var ir = ft.getBoundingClientRect();
          var ox = parseFloat(cell.dataset.ox), oy = parseFloat(cell.dataset.oy);
          cell.style.transition = first ? 'transform 2.6s cubic-bezier(.4,0,.2,1)' : 'transform 0.5s ease';
          cell.style.transform =
            'translate(' + ((ir.left + ir.width / 2) - ox).toFixed(1) + 'px,' +
            ((ir.top - 18) - oy).toFixed(1) + 'px)'; // 각주 텍스트 첫 줄 위(box가 안 겹치게)
        });
      }

      function accClose() {
        if (!accRow) return;
        var card = accRow.querySelector('.work-card');
        if (card && centerContent) centerContent.appendChild(card); // 저장소로 복귀
        if (accRow.parentNode) accRow.parentNode.removeChild(accRow);
        var tr = document.querySelector('tr[data-slug="' + accSlug + '"]');
        if (tr) tr.setAttribute('data-active', 'false');
        accRow = null;
        accSlug = null;
        renderFootnotes();
        drawLinks();
      }

      function accOpen(slug) {
        var tr = document.querySelector('tr[data-slug="' + slug + '"]');
        var card = document.getElementById(slug);
        if (!tr || !card) return;
        accClose();
        var detail = document.createElement('tr');
        detail.className = 'accordion-detail';
        var td = document.createElement('td');
        td.colSpan = 4;
        var panel = document.createElement('div');
        panel.className = 'accordion-panel';
        panel.appendChild(card);
        td.appendChild(panel);
        detail.appendChild(td);
        tr.parentNode.insertBefore(detail, tr.nextSibling);
        tr.setAttribute('data-active', 'true');
        accSlug = slug;
        accRow = detail;
        // 이펙트 없이 즉시 펼침. 펼친 행이 보이게만 스크롤(애니메이션 없음).
        tr.scrollIntoView({ block: 'start' });
        renderFootnotes();
        drawLinks();
      }
      // center 스크롤·창 리사이즈 시 연결선 좌표 갱신
      if (center) center.addEventListener('scroll', drawLinks);
      window.addEventListener('resize', drawLinks);

      // 본문 각주 마커(fn-ref) 클릭 → .right 패널의 해당 각주를 맨 위로 스크롤 + 강조
      document.addEventListener('click', function (e) {
        var ref = e.target.closest('.fn-ref a');
        if (!ref || !fnPanel) return;
        e.preventDefault();
        var sup = ref.closest('.fn-ref');
        var fn = sup ? sup.getAttribute('data-fn') : '';
        var card = ref.closest('.work-card');
        var slug = card ? card.id : '';
        var target = (fn && slug && fnList) ? fnList.querySelector('[id="fn-' + slug + '-' + fn + '"]') : null;
        if (target) {
          target.scrollIntoView({ block: 'start', behavior: 'smooth' });
          target.classList.add('fn-hl');
          setTimeout(function () { target.classList.remove('fn-hl'); }, 1600);
        }
      });

      // 필터/정렬 후 "보이는 첫 행"에 .first-visible (표 맨 위 가로선 제거용)
      function markFirstVisible() {
        var all = document.querySelectorAll('tr[data-slug]');
        all.forEach(function (tr) { tr.classList.remove('first-visible'); });
        for (var i = 0; i < all.length; i++) {
          if (!all[i].hidden) { all[i].classList.add('first-visible'); break; }
        }
      }

      function applyFilter(tag) {
        accClose();
        rows.forEach(function (tr) {
          var tags = (tr.getAttribute('data-tags') || '').split(' ');
          tr.hidden = tag !== 'all' && tags.indexOf(tag) === -1;
        });
        if (filter) {
          filter.querySelectorAll('[data-filter]').forEach(function (a) {
            a.setAttribute('data-active', String(a.getAttribute('data-filter') === tag));
          });
        }
        markFirstVisible();
      }

      // 모자이크 셀이 오른쪽 위 → 왼쪽 아래 대각선 순서로 떨어짐.
      // 100% 순차는 아니고 일부 셀은 예외 (random jitter).
      // opts(모두 선택): dur=한 셀 낙하시간(초), spread=대각선 wave 최대 delay(초),
      //   jitter=랜덤 흔들림, stragProb/stragMax=늦게 떨어지는 셀 비율/최대 delay,
      //   ease=타이밍 함수. 기본값 = 데스크탑 장식용. 전체 애니메이션 소요(ms) 반환.
      function triggerMosaicFall(opts) {
        if (!defaultEl) return 0;
        opts = opts || {};
        var dur = opts.dur != null ? opts.dur : 2.6;
        var spread = opts.spread != null ? opts.spread : 12;
        var jitter = opts.jitter != null ? opts.jitter : 1.7;
        var stragProb = opts.stragProb != null ? opts.stragProb : 0.12;
        var stragMax = opts.stragMax != null ? opts.stragMax : 13;
        var ease = opts.ease || 'cubic-bezier(0.95, 0, 1, 0.45)';
        var cells = defaultEl.querySelectorAll('.stripe-mosaic > div');
        var maxRow = 1, maxCol = 1;
        var positions = [];
        cells.forEach(function (d) {
          delete d.dataset.fast;
          delete d.dataset.skip;
          var ga = (d.style.gridArea || '').replace(/\s/g, '');
          var parts = ga.split('/');
          var row = parseInt(parts[0], 10) || 1;
          var col = parseInt(parts[1], 10) || 1;
          positions.push({ d: d, row: row, col: col });
          if (row > maxRow) maxRow = row;
          if (col > maxCol) maxCol = col;
        });
        var maxProgress = (maxCol - 1) + (maxRow - 1);
        var maxDelay = 0;
        positions.forEach(function (p) {
          p.d.style.animation = 'none';
          void p.d.offsetWidth; // reflow
          p.d.style.animation = 'cell-drop ' + dur.toFixed(3) + 's ' + ease + ' forwards';
          // 우상 → 좌하 대각선 진행도 (0~1)
          var progress = ((maxCol - p.col) + (p.row - 1)) / maxProgress;
          var delay;
          if (Math.random() < stragProb) {
            delay = Math.random() * stragMax;
          } else {
            delay = progress * spread + (Math.random() - 0.5) * jitter;
          }
          if (delay < 0) delay = 0;
          if (delay > maxDelay) maxDelay = delay;
          p.d.style.animationDelay = delay.toFixed(3) + 's';
        });
        defaultEl.dataset.falling = '1';
        return (maxDelay + dur) * 1000;
      }

      // URL hash ↔ 아코디언 동기화 (직접 #slug 진입, 뒤로가기, home 링크 대응).
      // 클릭 핸들러는 replaceState로 직접 열고/닫으므로 여기선 hashchange·초기 진입만 처리.
      function applyHash() {
        var slug = (location.hash || '').replace(/^#/, '');
        var hasSlug = slug && cards.some(function (c) { return c.id === slug; });
        if (hasSlug) {
          if (accSlug !== slug) accOpen(slug);
        } else {
          accClose();
        }
      }

      // 표 행 클릭 — 아코디언 토글 (그 아래로 카드 펼침)
      document.querySelectorAll('table.sontable a[href^="#"]').forEach(function (a) {
        a.addEventListener('click', function (e) {
          e.preventDefault();
          var slug = (a.getAttribute('href') || '').replace(/^#/, '');
          if (accSlug === slug) {
            accClose();
            if (location.hash) history.replaceState(null, '', location.pathname);
          } else {
            accOpen(slug);
            history.replaceState(null, '', '#' + slug);
          }
        });
      });

      if (filter) {
        filter.addEventListener('click', function (e) {
          var a = e.target.closest('[data-filter]');
          if (!a) return;
          e.preventDefault();
          applyFilter(a.getAttribute('data-filter'));
        });
      }

      // 표 정렬 — Year 기준. 기본 내림차순(최신 위), 클릭 시 토글.
      // 작품 카드 순서도 같이 reorder.
      function sortTable(order) {
        accClose(); // 정렬 전 아코디언 닫기 (detail 행이 재정렬되지 않게)
        var tbody = document.querySelector('table.sontable tbody');
        if (tbody) {
          var trs = Array.from(tbody.querySelectorAll('tr'));
          trs.sort(function (a, b) {
            // children[0]=번호 칸, children[1]=연도 칸
            var ya = parseInt((a.children[1] || {}).textContent || '0', 10) || 0;
            var yb = parseInt((b.children[1] || {}).textContent || '0', 10) || 0;
            return order === 'desc' ? yb - ya : ya - yb;
          });
          trs.forEach(function (tr) { tbody.appendChild(tr); });
        }
        var content = document.querySelector('.three-col .center .content');
        if (content) {
          var cs = Array.from(content.querySelectorAll('.work-card'));
          cs.sort(function (a, b) {
            var ya = parseInt(a.dataset.year || '0', 10) || 0;
            var yb = parseInt(b.dataset.year || '0', 10) || 0;
            return order === 'desc' ? yb - ya : ya - yb;
          });
          cs.forEach(function (c) { content.appendChild(c); });
        }
        markFirstVisible();
      }
      var sortToggle = document.querySelector('.sort-toggle');
      if (sortToggle) {
        sortToggle.addEventListener('click', function () {
          var cur = sortToggle.getAttribute('data-order') || 'desc';
          var next = cur === 'desc' ? 'asc' : 'desc';
          sortToggle.setAttribute('data-order', next);
          sortToggle.textContent = next === 'desc' ? '↓' : '↑';
          sortTable(next);
        });
      }
      sortTable('desc');

      // 표 제목 한·영 토글 — EN 버튼 클릭하면 표의 a 텍스트가 영어로
      var langToggle = document.querySelector('.lang-toggle');
      var threeCol = document.querySelector('.three-col');
      // 현재 언어를 .three-col에 반영 → 데스크탑에서 작품 본문 + about/footer가
      // 그 언어만 1단으로 표시됨 (양쪽 컬럼 모두 포함하려고 center 대신 three-col)
      function applyLang(lang) {
        if (threeCol) threeCol.setAttribute('data-lang', lang);
        document.querySelectorAll('table.sontable a[data-ko]').forEach(function (a) {
          a.textContent = a.getAttribute('data-' + lang) || '';
        });
        renderFootnotes();      // 언어 바뀌면 .right 각주 전체 재렌더
        settleFootnoteCells();  // 안착 네모를 새 각주 위치로 이동
        drawLinks();            // 연결선 갱신
      }
      if (langToggle) {
        applyLang(langToggle.getAttribute('data-lang') || 'ko'); // 초기 동기화
        langToggle.addEventListener('click', function () {
          var cur = langToggle.getAttribute('data-lang') || 'ko';
          var next = cur === 'ko' ? 'en' : 'ko';
          langToggle.setAttribute('data-lang', next);
          langToggle.textContent = next === 'ko' ? 'EN' : 'KO';
          applyLang(next);
        });
      }

      // 다크모드 토글 — 저장값(localStorage) > 시스템 설정 순.
      // 첫 페인트 전 적용은 Base.astro <head> 인라인 스크립트가 담당.
      // 버튼은 전환될 테마를 표시: 라이트일 때 ☾(→다크), 다크일 때 ☀(→라이트).
      var themeToggle = document.querySelector('.theme-toggle');
      if (themeToggle) {
        var darkMq = window.matchMedia('(prefers-color-scheme: dark)');
        var themeNow = function () {
          var t = document.documentElement.getAttribute('data-theme');
          return t || (darkMq.matches ? 'dark' : 'light');
        };
        var syncThemeIcon = function () {
          themeToggle.textContent = themeNow() === 'dark' ? '☀' : '☾';
        };
        themeToggle.addEventListener('click', function () {
          var next = themeNow() === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
          syncThemeIcon();
        });
        if (darkMq.addEventListener) darkMq.addEventListener('change', syncThemeIcon);
        syncThemeIcon();
      }

      // @로 시작하는 링크 텍스트 → mention 클래스 (인물 아이콘 + 갈색)
      function markMentions() {
        var sel = '.intro a, .work-card .card-body a, .work-card .card-link';
        document.querySelectorAll(sel).forEach(function (a) {
          var t = (a.textContent || '').trim();
          if (t.charAt(0) === '@') a.classList.add('mention');
        });
      }

      // 한글 char만 .ko span으로 감싸기 (영문 baseline에 맞춰 미세 위치 조정용)
      var KO_RE = /[ㄱ-힝]/;
      function wrapKoreanIn(root) {
        var skip = { SCRIPT: 1, STYLE: 1, NOSCRIPT: 1, IFRAME: 1, TEXTAREA: 1 };
        var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
          acceptNode: function (n) {
            var p = n.parentNode;
            if (!p) return NodeFilter.FILTER_REJECT;
            if (skip[p.nodeName]) return NodeFilter.FILTER_REJECT;
            if (p.classList && p.classList.contains('ko')) return NodeFilter.FILTER_REJECT;
            if (!KO_RE.test(n.nodeValue)) return NodeFilter.FILTER_REJECT;
            return NodeFilter.FILTER_ACCEPT;
          },
        });
        var nodes = [];
        while (walker.nextNode()) nodes.push(walker.currentNode);
        nodes.forEach(function (node) {
          var text = node.nodeValue;
          var frag = document.createDocumentFragment();
          var buf = '';
          var isKo = false;
          function flush() {
            if (!buf) return;
            if (isKo) {
              var span = document.createElement('span');
              span.className = 'ko';
              span.textContent = buf;
              frag.appendChild(span);
            } else {
              frag.appendChild(document.createTextNode(buf));
            }
            buf = '';
          }
          for (var i = 0; i < text.length; i++) {
            var ch = text.charAt(i);
            var ko = KO_RE.test(ch);
            if (ko !== isKo) {
              flush();
              isKo = ko;
            }
            buf += ch;
          }
          flush();
          node.parentNode.replaceChild(frag, node);
        });
      }
      function wrapAllKorean() {
        wrapKoreanIn(document.body);
      }

      // 줄무늬 띠 — viewport 폭에 따라 셀 개수 동적 계산
      var CELL_HEIGHT = 24;
      var CELL_RATIO = 0.5; // width / height — 0.5면 세로가 가로의 2배 길쭉
      function buildStripe() {
        var rows = document.querySelectorAll('.stripe-row');
        if (!rows.length) return;
        var desired = CELL_HEIGHT * CELL_RATIO;
        var N = Math.max(2, Math.round(window.innerWidth / desired));
        var pct = 100 / N;
        rows.forEach(function (row, rowIdx) {
          row.innerHTML = '';
          row.style.setProperty('--cell-w', pct + '%');
          for (var i = 0; i < N; i++) {
            var cell = document.createElement('div');
            var rowEven = rowIdx % 2 === 0;
            var evenCol = i % 2 === 0;
            // row 짝수(0,2,...): 짝수 col = purple. row 홀수(1,3,...): 짝수 col = brown.
            // → 3줄 이상이어도 위·아래·위·아래 패턴 유지.
            cell.className = 'cell ' + ((evenCol === rowEven) ? 'purple' : 'brown');
            row.appendChild(cell);
          }
        });
      }
      var stripeResizeT = null;
      window.addEventListener('resize', function () {
        clearTimeout(stripeResizeT);
        stripeResizeT = setTimeout(buildStripe, 100);
      });
      document.addEventListener('DOMContentLoaded', buildStripe);
      buildStripe();

      // hyuk.xyz 텍스트 클릭 → 홈(작품 선택 해제) + 모자이크 다시 떨어지기 시작
      document.querySelectorAll('[data-home]').forEach(function (a) {
        a.addEventListener('click', function (e) {
          e.preventDefault();
          accClose();
          if (location.hash) {
            history.pushState(null, '', location.pathname);
          }
          applyHash();
          if (defaultEl) {
            defaultEl.hidden = false;
            triggerMosaicFall();
          }
        });
      });

      // 떨어지는 중 mousemove — 마우스 주위 원형 영역의 셀들이 낱개로 자연스럽게 떨어짐.
      // 영역에 들어온 셀 중 50%만 trigger, 나머지 절반은 영구히 영향 무시.
      var moveThrottle = 0;
      document.addEventListener('mousemove', function (e) {
        if (!defaultEl || defaultEl.dataset.falling !== '1') return;
        var now = Date.now();
        if (now - moveThrottle < 60) return;
        moveThrottle = now;
        var nearRadius = 110; // 좁은 원형 영역
        var cells = defaultEl.querySelectorAll('.stripe-mosaic > div');
        cells.forEach(function (d) {
          if (d.dataset.fast === '1' || d.dataset.skip === '1' || d.dataset.footnote === '1') return; // 각주 안착 셀은 안 떨어뜨림
          var rect = d.getBoundingClientRect();
          if (rect.top > window.innerHeight + 50) return;
          var cx = rect.left + rect.width / 2;
          var cy = rect.top + rect.height / 2;
          var dist = Math.hypot(cx - e.clientX, cy - e.clientY);
          if (dist < nearRadius) {
            if (Math.random() < 0.7) {
              // animation을 새로 부여 — delay만 바꾸면 elapsed가 누적돼서
              // duration 초과 시 final state(화면 밖)로 점프 = 사라져 보임.
              var ratio = dist / nearRadius;
              var delay = Math.random() * 0.5 + ratio * 0.6;
              d.style.animation = 'none';
              void d.offsetWidth; // reflow
              d.style.animation = 'cell-drop 2.6s cubic-bezier(0.95, 0, 1, 0.45) forwards';
              d.style.animationDelay = delay.toFixed(3) + 's';
              d.dataset.fast = '1';
            } else {
              // 마우스 영향 영구히 무시
              d.dataset.skip = '1';
            }
          }
        });
      });

      window.addEventListener('hashchange', applyHash);
      document.addEventListener('DOMContentLoaded', applyHash);
      document.addEventListener('DOMContentLoaded', markMentions);
      document.addEventListener('DOMContentLoaded', wrapAllKorean);
      applyFilter('all');
      renderFootnotes(); // 모든 각주를 .right에 항상 표시
      applyHash();
      markMentions();
      wrapAllKorean();
      // 페이지 로드 시 모자이크 자동 낙하 (데스크탑 배경 장식 오버레이).
      // 모바일(≤600px)은 표 아코디언 테스트 방해 방지로 숨김 유지.
      if (defaultEl) {
        if (window.matchMedia('(max-width: 600px)').matches) {
          defaultEl.hidden = true;
        } else {
          defaultEl.hidden = false;
          triggerMosaicFall();
          settleFootnoteCells(); // N개 셀은 낙하 대신 각주 ■ 위치로 안착
        }
      }
    })();
  </script>
</Base>
