---
// 인덱스 — 3-col split:
//   left   : 인트로 + 푸터
//   center : 작품 표 + 아코디언 (행 클릭 시 그 아래로 카드 펼침)
//   right  : 비움 (새 컨텐츠 예정)
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';
import SkelImage from '../components/SkelImage.astro';
import { getWorks, resolveImage, resolveVideo, getIntro, getIntroNotes, getLinks, getMemos, groupBilingual } from "../lib/site-data.js";
import { buildTagMixMap } from "../lib/tag-colors.js";

const works = getWorks().slice().sort((a, b) => {
  // 표 정렬 — year desc(최신 위), 같은 연도는 stable sort로 index 채널 순서 유지.
  const ya = parseInt(a.year || '0', 10) || 0;
  const yb = parseInt(b.year || '0', 10) || 0;
  return yb - ya;
});

function orderedTagsOf(w: (typeof works)[number]): string[] {
  // 태그 전부 표시 — non-web 먼저, web은 맨 뒤. (표 카테고리 칸)
  const nonWeb = w.tags.filter((x) => x !== 'web');
  return w.tags.includes('web') ? [...nonWeb, 'web'] : nonWeb;
}

const introGroups = getIntro(); // About 서랍 — footer 채널은 intro로 통폐합됨
const introNotes = getIntroNotes(); // 2단 본문 아래 1단 주석(## note 블록)
// 우측 컬럼 수집 링크 — Are.na links 채널의 링크 블록들 (채널 순서)
const siteLinks = getLinks();
// 좌측 컬럼 메모 — memo 채널 텍스트 블록 (채널 순서)
const memos = getMemos();

// 블록 추가 시점 표기 — Are.na의 "added"처럼. ISO → YYYY.MM.DD
const fmtDate = (iso: string) => (iso ? iso.slice(0, 10).replaceAll('-', '.') : '');

// 메모·링크·콜로폰 일시 — 초 단위까지, 빌드 머신(CI=UTC)과 무관하게 KST 고정
const fmtDateTime = (iso: string) => {
  if (!iso) return '';
  const parts = new Intl.DateTimeFormat('en-CA', {
    timeZone: 'Asia/Seoul',
    year: 'numeric', month: '2-digit', day: '2-digit',
    hour: '2-digit', minute: '2-digit', second: '2-digit', hourCycle: 'h23',
  }).formatToParts(new Date(iso));
  const g = (t: string) => parts.find((p) => p.type === t)?.value ?? '';
  return `${g('year')}.${g('month')}.${g('day')} ${g('hour')}:${g('minute')}:${g('second')}`;
};

// 우측 드롭다운용 — 수집 링크에 등장하는 태그 목록 (채널 순서대로, 중복 제거)
const linkTags = [...new Set(siteLinks.flatMap((l) => l.tags))];
// 태그 색 맵 — 전체(memo+컬렉션) 태그를 정렬해 두 테마색 사이 hue를 균등 분할(mix %)
const tagMixMap = buildTagMixMap([
  ...memos.flatMap((m) => m.tags),
  ...siteLinks.flatMap((l) => l.tags),
]);

// 하단 콜로폰 — 빌드 시각 (SSG라 = 콘텐츠 스냅샷 시각)
const buildStamp = fmtDateTime(new Date().toISOString());


// 작품 선택 안 한 기본 화면용 모자이크 (stripe-mosaic 도구로 만든 단일 SVG → 셀 그리드)
const defaultMosaic = fs.readFileSync(
  path.join(process.cwd(), 'src/data/default-mosaic.html'),
  'utf-8',
);
---

<Base title="hyuk.xyz">
  {/* 줄(.stripe-row)은 JS buildStripe가 화면 높이만큼 생성 — 기본 노출은 위 72px.
      띠를 아래로 땡기면 커튼이 따라 내려오고 그 위에 About 패널이 인쇄된다(서랍).
      위로 땡기면/천 탭/ESC로 닫힘 — 별도 버튼 없음. (drawer.js) */}
  <div class="stripe-top" role="button" tabindex="0" aria-label="about — 아래로 당겨 열기"></div>
  {/* 띠 우측 칩 — 언어 토글 (about 탭은 드래그 인터랙션으로 폐지) */}
  <button type="button" class="lang-toggle" data-lang="en">KO</button>
  {/* 왼쪽 위 — About 토글. 누르면 가운데(작품 표) 위로 About 오버레이가 덮인다. */}
  <button type="button" class="about-toggle" aria-expanded="false">Hyuk Jang</button>
  {/* 방명록 서랍 — 커튼(형제) 위에 얹히는 패널 레이어. 띠를 끌어내려 연다.
      천 클릭은 통과시켜 stripe 토글로 가고, 패널 자신만 클릭을 소화한다.
      읽기는 JSONP, 쓰기는 no-cors POST (구글 시트 Apps Script). */}
  <div class="about-drawer" data-lang="en">
    {/* 남겨진 메시지들 — 커튼 위를 하나씩 떠다닌다 (JS가 채움) */}
    <div class="gb-float-layer" aria-hidden="true"></div>
    {/* 입력창 — 한 영역처럼: 상단 arena-path 라벨(드래그 핸들) + 아래 구분선.
        기본 화면 중앙, 라벨을 잡고 커튼 안에서 옮길 수 있다. */}
    <div class="drawer-panel guestbook">
      <div class="gb-path" title="잡고 옮기기" aria-hidden="true"></div>
      <form class="gb-form">
        <input class="gb-name" type="text" maxlength="40" placeholder="이름 (선택)" autocomplete="off" />
        {/* 입력칸 — 기본 리사이즈 손잡이 대신 바닥 가로선을 핸들로(커서로 늘림 표시) */}
        <div class="gb-field">
          <textarea class="gb-message" maxlength="500" rows="3" placeholder="한마디 남기기…" required></textarea>
          <div class="gb-resize" aria-hidden="true"></div>
        </div>
        <div class="gb-actions">
          <span class="gb-status" aria-live="polite"></span>
          <button type="submit" class="gb-submit">남기기</button>
        </div>
      </form>
    </div>
  </div>
  {/* data-section: 모바일 섹션 페이저 상태 — 기본 Portfolio. 데스크탑 CSS는 무시 */}
  <div class="three-col" data-section="portfolio">
    {/* 세로 구분선 — d1/d2: 3구역(메모|작품|수집) 경계, 전체 높이.
        표 컬럼 내부선(번호|제목|분류)은 좌표 고정이 아니라 표 셀 border가 직접 그린다. */}
    <div class="col-divider d1" aria-hidden="true"></div>
    <div class="col-divider d2" aria-hidden="true"></div>

    {/* About 오버레이 — 'Hyuk Jang' 버튼이 토글. 가운데(작품 표) 위를 덮는다.
        한/영 전환은 .three-col[data-lang] 규칙을 그대로 탄다. */}
    <div class="about-overlay" id="aboutOverlay" hidden>
      <div class="arena-path"><span aria-hidden="true">Are.na/Hyuk Jang/About</span></div>
      {introGroups.length > 0 && (
        <div class="intro-body">
          {
            introGroups.map((g, i) => (
              <div class="intro-group" style={`--i:${i}`}>
                {g.ko && g.en ? (
                  <div class="bilingual">
                    <div class="ko-body" lang="ko" set:html={g.ko} />
                    <div class="en-body" lang="en" set:html={g.en} />
                  </div>
                ) : g.ko ? (
                  <div lang="ko" set:html={g.ko} />
                ) : (
                  <div lang="en" set:html={g.en} />
                )}
              </div>
            ))
          }
        </div>
      )}
      {introNotes.length > 0 && (
        <div class="intro-notes">
          {introNotes.map((html) => <div class="intro-note" set:html={html} />)}
        </div>
      )}
    </div>

    {/* ──────────── 좌측: 메모 — Are.na memo 채널의 텍스트 블록 아코디언.
        접힌 라벨 클릭 → 본문 펼침 (한 번에 하나). 인물 레지스트리는
        본문 @멘션 매칭용으로 데이터에서 계속 동작 ──────────── */}
    <div class="third left">
      <div class="content intro">
        {/* 영역 출처 — Are.na를 그대로 쓰고 있음을 드러내는 경로 라벨.
            .path-arrow = 모바일 섹션 페이저 화살표 (데스크탑 숨김) */}
        <div class="arena-path">
          <span aria-hidden="true">Are.na/Hyuk Jang/Notepad</span>
          <button type="button" class="path-arrow next" data-go="portfolio" aria-label="Portfolio 보기">→</button>
        </div>
        {memos.length > 0 && (
          <div class="memo-list">
            {memos.map((m, i) => (
              <>
                {i > 0 && <hr />}
                {/* 블록 전체가 토글 단위 — 라벨/날짜/본문 어디를 눌러도 접고 펼침.
                    row-a/row-b = 호버 배경 보라/갈색 2색 교차 (.right 링크와 같은 어법) */}
                <div class={`memo ${i % 2 === 0 ? 'row-a' : 'row-b'}`} role="button" tabindex="0">
                  <span class="memo-head">{m.title}</span>
                  {(m.addedAt || m.tags.length > 0) && (
                    <span class="block-date">
                      {fmtDateTime(m.addedAt)}{m.addedBy && ` · ${m.addedBy}`}{m.tags.map((t) => (
                        <>{' · '}<span class="tag-chip" style={`--mix:${tagMixMap.get(t)}%`}>#{t}</span></>
                      ))}
                    </span>
                  )}
                  {/* 서식 없이 원문 그대로 (줄바꿈 유지). 맨 아래 = 원 블록으로 가는 출처 링크 */}
                  <div class="memo-body">{m.text}{m.id && (
                    <a class="memo-source" href={`https://www.are.na/block/${m.id}`} target="_blank" rel="noopener">↗ are.na/block/{m.id}</a>
                  )}</div>
                </div>
              </>
            ))}
          </div>
        )}
      </div>
    </div>

    {/* ──────────── 중앙: 작품 표 + 카드 아코디언 ──────────── */}
    <div class="third center">
      <div class="content">
        <div class="arena-path">
          <button type="button" class="path-arrow prev" data-go="notepad" aria-label="Notepad 보기">←</button>
          <span aria-hidden="true">Are.na/Hyuk Jang/Portfolio</span>
          <button type="button" class="path-arrow next" data-go="collection" aria-label="Collection 보기">→</button>
        </div>
        {/* 작품 미선택 시 배경 모자이크 — fixed 오버레이, 로드 시 자동 낙하 */}
        <div class="default-state" id="__default" hidden>
          <Fragment set:html={defaultMosaic} />
        </div>
        {/* 작품 표 — 행 클릭 시 바로 아래로 카드(이미지+본문) 아코디언 펼침.
            컨트롤 헤더(필터·정렬) 없이 표가 컬럼 최상단에서 바로 시작 */}
        {works.length > 0 ? (
          <table class="sontable">
            <colgroup>
              <col class="col-num" />
              <col class="col-title" />
              <col class="col-cat" />
            </colgroup>
            <tbody>
              {works.map((w, i) => (
                <tr data-slug={w.slug} data-locked={w.published ? undefined : 'true'} aria-expanded={w.published ? 'false' : undefined} class={i % 2 === 0 ? 'row-a' : 'row-b'}>
                  {/* 번호 = 연도 내림차순 고정. row-a/row-b = 호버 배경 보라/갈색
                      2색 교차 (빌드 시 행 인덱스로, .right 링크와 같은 어법). */}
                  <td class="num-cell"><span class="num-badge">{i + 1}</span></td>
                  <td class="title-cell">
                    {w.published ? (
                      <a href={`#${w.slug}`} data-ko={w.title || w.slug} data-en={w.titleEn || w.title || w.slug}>
                        {w.title || w.slug}
                      </a>
                    ) : (
                      // 미게시 — 펼침 불가. 링크가 아닌 잠긴 라벨 (언어 스왑은 유지)
                      <span class="locked-title" data-ko={w.title || w.slug} data-en={w.titleEn || w.title || w.slug}>
                        {w.title || w.slug}
                      </span>
                    )}
                  </td>
                  <td class="cat-cell">
                    {orderedTagsOf(w).length
                      ? orderedTagsOf(w).map((t) => (
                          <span class="cat-tag" data-tag={t}>{t}</span>
                        ))
                      : '—'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p>아직 작품이 없습니다.</p>
        )}

        {
          /* 미게시 작업은 펼칠 수 없으므로 카드를 만들지 않는다 (표 행만 남음) */
          works.filter((w) => w.published).map((w) => {
            const cover = w.cover ? resolveImage(w.cover) : undefined;
            const externalUrl = w.links[0]?.url;
            const isWeb = w.tags.includes('web');
            // 본문 맨 위 간략 정보 — 연도·재료·규격·클라이언트(있는 것만), 줄바꿈 구분. 회색 파생색.
            const infoParts = [w.year, w.medium, w.size, w.client].filter(Boolean);
            return (
              <article class="work-card" id={w.slug}>
                <h2 class="card-title">
                  {w.titleEn && w.titleEn !== w.title && (
                    <span class="card-title-en" lang="en">{w.titleEn}</span>
                  )}
                  <span class="card-title-ko" lang="ko">{w.title || w.slug}</span>
                </h2>
                <p class="card-meta">
                  {w.year}
                  {w.tags.length > 0 && <> · {w.tags.join(' · ')}</>}
                </p>

                {isWeb && externalUrl ? (
                  <div class="iframe-wrap t-skel">
                    <iframe
                      src={externalUrl}
                      class="embedded-iframe"
                      title={w.title || w.slug}
                      loading="lazy"
                      allowfullscreen
                    ></iframe>
                    <div class="t-skel-skeleton is-pulsing" aria-hidden="true"><span class="t-skel-bar"></span></div>
                  </div>
                ) : w.images.length > 0 ? (
                  <div class="card-images">
                    {(() => {
                      // imageLayout이 있으면 [cols, cols, ...] 그룹별로 grid row 생성.
                      // 없거나 합 불일치면 그냥 stack (한 줄에 한 장).
                      const layout =
                        w.imageLayout && w.imageLayout.length > 0
                          ? w.imageLayout
                          : w.images.map(() => 1);
                      const rows: { cols: number; imgs: typeof w.images }[] = [];
                      let i = 0;
                      for (const cols of layout) {
                        rows.push({ cols, imgs: w.images.slice(i, i + cols) });
                        i += cols;
                      }
                      return rows.map((row) => (
                        <div
                          class="image-row"
                          style={`grid-template-columns: repeat(${row.cols}, 1fr)`}
                        >
                          {row.imgs.map((img) => {
                            // 영상: 자동재생·무한루프·음소거·컨트롤 없음 — 움직이는 이미지처럼.
                            if (img.kind === 'video') {
                              const vsrc = resolveVideo(img.localPath);
                              const poster = img.poster ? resolveImage(img.poster) : undefined;
                              return vsrc ? (
                                <video
                                  class="card-video"
                                  src={vsrc}
                                  poster={poster?.src}
                                  autoplay
                                  loop
                                  muted
                                  playsinline
                                  preload="metadata"
                                  aria-label={img.alt || w.title || w.slug}
                                ></video>
                              ) : null;
                            }
                            const asset = resolveImage(img.localPath);
                            return asset ? (
                              <SkelImage
                                src={asset}
                                alt={img.alt || w.title || w.slug}
                                widths={[420, 640, 960]}
                                sizes={row.cols === 1 ? '40vw' : `${40 / row.cols}vw`}
                              />
                            ) : null;
                          })}
                        </div>
                      ));
                    })()}
                  </div>
                ) : cover ? (
                  <SkelImage src={cover} alt={w.title || w.slug} widths={[420, 640, 960]} sizes="40vw" />
                ) : null}

                {(infoParts.length > 0 ||
                  w.bodyBlocks.some((b) => b.lang === null && b.html) ||
                  w.bodyBlocks.some((b) => b.lang !== null && b.html) ||
                  externalUrl) && (
                  <div class="card-body">
                    {/* 본문 맨 위 간략 정보 — 연도·재료·규격·클라이언트, 줄바꿈 구분·회색 파생색 */}
                    {infoParts.length > 0 && (
                      <p class="card-info">{infoParts.map((p, i) => (
                        <>{i > 0 && <br />}{p}</>
                      ))}</p>
                    )}
                    {/* 규격(lang null) + 웹링크 — 본문 위. 둘 다 있으면(웹작업) 2단. */}
                    {(w.bodyBlocks.some((b) => b.lang === null && b.html) || externalUrl) && (
                      <div class="card-meta-row">
                        {w.bodyBlocks.filter((b) => b.lang === null && b.html).map((b) => (
                          <div class="card-spec" set:html={b.html} />
                        ))}
                        {externalUrl && (
                          <p class="card-link-wrap">
                            <a href={externalUrl} target="_blank" rel="noopener" class="card-link">
                              {w.title || w.slug}
                            </a>
                          </p>
                        )}
                      </div>
                    )}
                    {
                      groupBilingual(w.bodyBlocks.filter((b) => b.lang !== null)).map((g) => (
                        g.ko && g.en ? (
                          <div class="bilingual">
                            <div lang="ko" set:html={g.ko} />
                            <div lang="en" set:html={g.en} />
                          </div>
                        ) : g.ko ? (
                          <div lang="ko" set:html={g.ko} />
                        ) : (
                          <div lang="en" set:html={g.en} />
                        )
                      ))
                    }
                  </div>
                )}
              </article>
            );
          })
        }

      </div>
    </div>

    {/* ──────────── 우측: 수집 링크 (Are.na links 채널) — 언어 토글은 띠 위로 이사 ──────────── */}
    <div class="third right">
      <div class="content">
        <div class="arena-path">
          <button type="button" class="path-arrow prev" data-go="portfolio" aria-label="Portfolio 보기">←</button>
          <span aria-hidden="true">Are.na/Hyuk Jang/Collection</span>
        </div>
        {/* 제목만 — 가운데 (설명은 데이터에만 보관) */}
        {siteLinks.length > 0 && (
          <nav class="link-list" aria-label="collected links">
            {/* 태그 드롭다운 — 채널에 태그가 하나라도 있을 때만 */}
            {linkTags.length > 0 && (
              <>
                {/* 브라우저 기본 셀렉트 그대로 — 줄 높이만 4px 격자에 고정 */}
                <label class="link-filter">
                  <select id="linkTagFilter" aria-label="태그별 필터">
                    <option value="">all</option>
                    {linkTags.map((t) => (
                      <option value={t}>{t}</option>
                    ))}
                  </select>
                </label>
                <hr />
              </>
            )}
            {siteLinks.map((l, i) => (
              <>
                {i > 0 && <hr />}
                <a
                  class={`link-item ${i % 2 === 0 ? 'row-a' : 'row-b'}`}
                  href={l.url}
                  target="_blank"
                  rel="noopener"
                  data-tags={l.tags.join(',')}
                >
                  <span class="link-title">{l.title || l.url}</span>
                  {(l.addedAt || l.tags.length > 0) && (
                    <span class="block-date">
                      {fmtDateTime(l.addedAt)}{l.tags.map((t) => (
                        <>{' · '}<span class="tag-chip" data-tag={t} style={`--mix:${tagMixMap.get(t)}%`}>#{t}</span></>
                      ))}
                    </span>
                  )}
                </a>
              </>
            ))}
          </nav>
        )}
      </div>
    </div>

    {/* ──────────── 하단: 3칸 그리드(20/60/20) — 좌 built / 중앙 웹링 / 우 now.
