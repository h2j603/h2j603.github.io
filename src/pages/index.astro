---
// Work index — list every published work, ordered by `order`.
// Intentionally UNSTYLED: this page only proves the data pipeline flows.
import { getWorks } from '../lib/site-data.js';

const works = getWorks();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Works</title>
  </head>
  <body>
    <h1>Works</h1>
    {works.length === 0 && <p>No works yet. Run <code>npm run build</code>.</p>}
    <ul>
      {
        works.map((w) => (
          <li data-tags={w.tags.join(' ')}>
            <a href={`/works/${w.slug}/`}>{w.title || w.slug}</a>
            {w.year && <span> — {w.year}</span>}
            {w.medium && <span> · {w.medium}</span>}
            {w.tags.length > 0 && <span> [{w.tags.join(', ')}]</span>}
          </li>
        ))
      }
    </ul>
  </body>
</html>
