---
// 하이퍼링크 스타일 실험실 — 시안 비교용 별도 페이지 (/links-lab).
// 사이트 어디서도 링크되지 않는 숨은 라우트. 폰에서 hyuk.xyz/links-lab 로 확인.
// 사이트 팔레트·폰트를 Base로 상속. 각 시안은 .v vN 클래스로 스코프(실사이트 무영향).
import Base from '../layouts/Base.astro';

// 시안 목록 — n(번호)·name·desc. 마크업은 아래에서 공통 샘플 문장으로 렌더.
const variants = [
  { n: 1,  name: '필 (현재)',        desc: '틴트 배경 pill — 지금 사이트 방식' },
  { n: 2,  name: '밑줄 · 기본',       desc: '오프셋 밑줄, 호버 시 굵게' },
  { n: 3,  name: '밑줄 · 슬라이드인',  desc: '평소 없음 → 호버 시 왼→오른쪽으로 그어짐' },
  { n: 4,  name: '하이라이트 라인',    desc: '베이스라인에 두꺼운 틴트 선, 호버 시 차오름' },
  { n: 5,  name: '마커펜',           desc: '테마색 두 개 그대로 배경 + 흰 글자, 호버 시 살짝 진하게' },
  { n: 6,  name: '점선 밑줄',         desc: '각주 어법, 호버 시 실선' },
  { n: 7,  name: '대괄호 [ ]',        desc: '이름을 대괄호로 감쌈, 호버 시 밑줄' },
  { n: 8,  name: '화살표 ↗',         desc: '색 글자 + 외부 화살표 접미' },
  { n: 9,  name: '아웃라인 박스',      desc: '얇은 테두리 pill, 호버 시 배경 채움' },
  { n: 10, name: '컬러만 → 호버 밑줄', desc: '가장 미니멀 — 색 글자, 호버에만 밑줄' },
  { n: 11, name: '물결 밑줄',         desc: 'wavy 밑줄 — 장식적' },
  { n: 12, name: '배경 스윕',         desc: '호버 시 pill 배경이 왼→오른쪽으로 차오름' },
];
---

<Base title="Link Lab — hyuk.xyz">
  <main class="lab">
    <header class="lab-head">
      <h1>하이퍼링크 시안</h1>
      <p class="lab-sub">
        같은 문장에 스타일만 바꿔 12종. <b>일반 링크</b>(보라)와 <b>인물 링크</b>(갈색)를
        나란히 뒀어. 호버해보고 마음에 드는 번호 알려줘.
      </p>
      <div class="lab-palette">
        <span>팔레트</span>
        <button type="button" data-pal="original">original</button>
        <button type="button" data-pal="blue">blue</button>
        <button type="button" data-pal="gold">gold</button>
      </div>
    </header>

    <div class="lab-grid">
      {variants.map((v) => (
        <section class="card">
          <div class="card-tag">
            <span class="num">{String(v.n).padStart(2, '0')}</span>
            <span class="nm">{v.name}</span>
          </div>
          <p class="card-desc">{v.desc}</p>
          <p class="sample">
            그래픽 디자이너 장혁입니다. 주로 <a href="#" class={`v v${v.n}`}>Are.na</a>에서
            자료를 모으고, <a href="#" class={`v v${v.n} person`}>김민수</a>와 함께{' '}
            <a href="#" class={`v v${v.n}`}>전시 웹사이트</a>를 만들었습니다.
          </p>
          <p class="sample en" lang="en">
            I collect references on <a href="#" class={`v v${v.n}`}>Are.na</a> and built an{' '}
            <a href="#" class={`v v${v.n}`}>exhibition site</a> with{' '}
            <a href="#" class={`v v${v.n} person`}>Minsu Kim</a>.
          </p>
        </section>
      ))}
    </div>
  </main>
</Base>

<style>
  .lab {
    max-width: 60rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    background: var(--bg);
    color: var(--ink-body);
  }
  .lab-head { margin-bottom: 2.5rem; }
  .lab h1 { font-size: 1.6rem; color: var(--ink); letter-spacing: 0.01em; margin-bottom: 0.6rem; }
  .lab-sub { font-size: 0.95rem; line-height: 1.7; max-width: 42rem; }
  .lab-sub b { color: var(--ink); font-weight: 600; }
  .lab-palette { display: flex; align-items: center; gap: 0.5rem; margin-top: 1.25rem; font-size: 0.8rem; }
  .lab-palette span { color: var(--muted); }
  .lab-palette button {
    font: inherit; font-size: 0.8rem; cursor: pointer;
    border: 1px solid var(--ring); background: transparent; color: var(--ink);
    border-radius: 999px; padding: 0.1rem 0.7rem;
  }
  .lab-palette button:hover { background: var(--tint-accent); }

  .lab-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--ink);              /* 셀 사이 1px 괘선 (사이트 어법) */
    border: 1px solid var(--ink);
  }
  @media (max-width: 640px) { .lab-grid { grid-template-columns: 1fr; } }
  .card { background: var(--bg); padding: 1.25rem 1.4rem 1.6rem; }
  .card-tag { display: flex; align-items: baseline; gap: 0.55rem; }
  .card-tag .num { font-size: 0.75rem; color: var(--muted); font-variant-numeric: tabular-nums; }
  .card-tag .nm  { font-size: 0.95rem; color: var(--ink); font-weight: 600; }
  .card-desc { font-size: 0.8rem; color: var(--muted); margin: 0.25rem 0 0.9rem; line-height: 1.5; }
  .sample { font-size: 1.05rem; line-height: 2.05; color: var(--ink-body); }
  .sample.en { font-size: 0.9rem; line-height: 1.9; margin-top: 0.5rem; opacity: 0.85; }

  /* ── 링크 색 패밀리 — 일반(보라)/인물(갈색). 각 시안은 이 지역 변수만 참조. ── */
  .lab .v {
    --lc: var(--accent);
    --lt: var(--tint-accent);
    --ls: var(--stripe-a);          /* 테마 소스색 그대로 (보라) */
    --lp-grad: var(--pill-link-grad);
    --lp-grad-h: var(--pill-link-grad-h);
    --lp-text: var(--pill-link-text);
    cursor: pointer;
    font-style: normal;   /* 전역 a 이탤릭 상속 제거 — 시안 공정 비교(upright) */
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }
  .lab .v.person {
    --lc: var(--person);
    --lt: var(--tint-brown);
    --ls: var(--stripe-b);          /* 테마 소스색 그대로 (갈) */
    --lp-grad: var(--pill-person-grad);
    --lp-grad-h: var(--pill-person-grad-h);
    --lp-text: var(--pill-person-text);
  }

  /* 01 필 (현재) */
  .v1 { text-decoration: none; color: var(--lp-text); background: var(--lp-grad);
        padding: 0.0625rem var(--space-pill); border-radius: 0.75rem; }
  .v1:hover { background: var(--lp-grad-h); }

  /* 02 밑줄 · 기본 */
  .v2 { color: var(--lc); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
  .v2:hover { text-decoration-thickness: 2px; }

  /* 03 밑줄 · 슬라이드인 */
  .v3 { color: var(--lc); text-decoration: none; padding-bottom: 2px;
        background-image: linear-gradient(var(--lc), var(--lc));
        background-size: 0% 1.5px; background-position: 0 100%; background-repeat: no-repeat;
        transition: background-size 0.28s ease; }
  .v3:hover { background-size: 100% 1.5px; }

  /* 04 하이라이트 라인 (차오름) */
  .v4 { color: var(--ink); text-decoration: none;
        box-shadow: inset 0 -0.32em 0 var(--lt); transition: box-shadow 0.2s ease; }
  .v4:hover { box-shadow: inset 0 -0.9em 0 var(--lt); }

  /* 05 마커펜 — 테마색 두 개(stripe-a/b) 그대로 배경 + 흰 글자 */
  .v5 { color: #fff; text-decoration: none; background: var(--ls);
        padding: 0.05em 0.22em; border-radius: 2px; transition: filter 0.18s ease; }
  .v5:hover { filter: brightness(0.92); }

  /* 06 점선 밑줄 */
  .v6 { color: var(--lc); text-decoration: underline dotted; text-decoration-thickness: 1px; text-underline-offset: 3px; }
  .v6:hover { text-decoration-style: solid; }

  /* 07 대괄호 [ ] */
  .v7 { color: var(--lc); text-decoration: none; }
  .v7::before { content: '['; }
  .v7::after  { content: ']'; }
  .v7::before, .v7::after { color: var(--lc); opacity: 0.45; }
  .v7:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* 08 화살표 ↗ */
  .v8 { color: var(--lc); text-decoration: none; }
  .v8::after { content: '↗'; font-size: 0.82em; margin-left: 0.05em; }
  .v8:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* 09 아웃라인 박스 */
  .v9 { color: var(--lc); text-decoration: none;
        border: 1px solid color-mix(in oklab, var(--lc) 45%, transparent);
        border-radius: 0.6rem; padding: 0.02rem 0.42rem;
        transition: background 0.18s ease, border-color 0.18s ease; }
  .v9:hover { background: var(--lt); border-color: var(--lc); }

  /* 10 컬러만 → 호버 밑줄 */
  .v10 { color: var(--lc); text-decoration: none; }
  .v10:hover { text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }

  /* 11 물결 밑줄 */
  .v11 { color: var(--lc); text-decoration: underline wavy; text-decoration-thickness: 0.5px; text-underline-offset: 3px; }

  /* 12 배경 스윕 */
  .v12 { color: var(--lc); text-decoration: none; border-radius: 0.75rem;
         padding: 0.0625rem var(--space-pill);
         background-image: var(--lp-grad-h); background-size: 0% 100%;
         background-position: 0 0; background-repeat: no-repeat;
         transition: background-size 0.28s ease, color 0.2s ease; }
  .v12:hover { background-size: 100% 100%; color: var(--lp-text); }
</style>

<script is:inline>
  // 팔레트 미리보기 — 3종 토글 (실사이트 palette.js와 무관, 이 페이지 전용).
  document.querySelectorAll('.lab-palette button').forEach(function (b) {
    b.addEventListener('click', function () {
      document.documentElement.dataset.palette = b.getAttribute('data-pal');
    });
  });
</script>
