---
// 작품 상세 — 메타 + 이미지 시퀀스 + 좌우 한·영 본문 + 링크.
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { getWorks, resolveImage } from '../../lib/site-data.js';

export function getStaticPaths() {
  return getWorks().map((work) => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

const { work } = Astro.props;
const title = work.title || work.slug;
const metaRows = [
  ['Year', work.year],
  ['Medium', work.medium],
  ['Size', work.size],
  ['Client', work.client],
].filter(([, v]) => v);
---

<Base title={`${title} — hyuk.xyz`}>
  <article class="work">
    <p class="back"><a href="/">← Works</a></p>

    <h1 class="h-page work-title">{title}</h1>

    {(metaRows.length > 0 || work.tags.length > 0) && (
      <dl class="work-meta">
        {metaRows.map(([k, v]) => (
          <>
            <dt>{k}</dt>
            <dd>{v}</dd>
          </>
        ))}
        {work.tags.length > 0 && (
          <>
            <dt>Tags</dt>
            <dd>{work.tags.map((t) => <span class="tag">{t}</span>)}</dd>
          </>
        )}
      </dl>
    )}

    {work.images.length > 0 && (
      <section class="images">
        {
          work.images.map((img, i) => {
            const asset = resolveImage(img.localPath);
            return asset ? (
              <figure>
                <Image
                  src={asset}
                  alt={img.alt}
                  widths={[640, 960, 1280, 1600]}
                  sizes="(min-width: 1024px) 80vw, 100vw"
                />
                {img.caption && (
                  <figcaption class="caption">
                    Fig. {String(i + 1).padStart(2, '0')} · {img.caption}
                  </figcaption>
                )}
              </figure>
            ) : (
              <p class="missing">⚠ missing image asset: {img.localPath}</p>
            );
          })
        }
      </section>
    )}

    {(work.bodyKo || work.bodyEn) && (
      <section class="body-block">
        <div class="body-col" lang="ko">
          <p class="h-section">KO</p>
          {work.bodyKo
            ? <div class="prose" set:html={work.bodyKo} />
            : <p class="muted">—</p>}
        </div>
        <div class="body-col" lang="en">
          <p class="h-section">EN</p>
          {work.bodyEn
            ? <div class="prose" set:html={work.bodyEn} />
            : <p class="muted">—</p>}
        </div>
      </section>
    )}

    {work.links.length > 0 && (
      <section class="links">
        <p class="h-section">Links</p>
        <ul>
          {
            work.links.map((link) => {
              const thumb = link.thumbnail ? resolveImage(link.thumbnail) : undefined;
              return (
                <li>
                  <a href={link.url} target="_blank" rel="noopener">
                    {thumb && (
                      <Image src={thumb} alt={link.title || link.url} width={96} height={96} />
                    )}
                    <span>
                      <strong>{link.title || link.url}</strong>
                      {link.description && <em class="meta"> — {link.description}</em>}
                    </span>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </section>
    )}
  </article>
</Base>

<style>
  .work { padding: 40px 0 0; }

  .back {
    font-size: 13px;
    color: var(--brown);
    margin-bottom: 24px;
  }
  .back a:hover { color: var(--accent); }

  .work-title { margin-bottom: 24px; }

  /* 메타 dl — dt: 작은 라벨(브라운 캡스) / dd: 값 */
  .work-meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 16px;
    row-gap: 4px;
    max-width: 520px;
    font-size: 14px;
    padding: 16px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .work-meta dt {
    color: var(--brown);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 11px;
    align-self: center;
  }
  .work-meta dd { margin: 0; }

  /* 이미지 시퀀스 */
  .images {
    margin-top: 56px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  .images figure { margin: 0; }
  .images img {
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
  }
  .caption {
    margin-top: 10px;
    color: var(--muted);
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  /* 좌우 본문 — 데스크탑 2단, 모바일 1단 */
  .body-block {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 720px) {
    .body-block { grid-template-columns: 1fr; gap: 32px; }
  }
  .body-col .h-section { margin-bottom: 12px; }

  .prose {
    font-size: 15px;
    line-height: 1.75;
    max-width: 520px;
  }
  .prose :global(p) { margin: 0; }
  .prose :global(p + p),
  .prose :global(p + ul),
  .prose :global(p + ol),
  .prose :global(ul + p),
  .prose :global(ol + p),
  .prose :global(h2 + p),
  .prose :global(h3 + p) {
    margin-top: 12px;
  }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(em) { font-style: italic; color: var(--brown); }
  .prose :global(a) {
    color: var(--accent);
    border-bottom: 1px solid currentColor;
  }
  .prose :global(h2),
  .prose :global(h3) {
    font-size: 15px;
    font-weight: 600;
    margin-top: 24px;
    margin-bottom: 8px;
  }
  .prose :global(ul) { list-style: disc; padding-left: 18px; }
  .prose :global(ol) { list-style: decimal; padding-left: 18px; }

  /* 링크 */
  .links {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
  }
  .links .h-section { margin-bottom: 16px; }
  .links ul { display: flex; flex-direction: column; gap: 16px; }
  .links a {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .links a img {
    width: 64px;
    height: 64px;
    object-fit: cover;
    border: 1px solid var(--line);
  }
  .links strong {
    font-weight: 600;
    border-bottom: 1px solid transparent;
  }
  .links a:hover strong {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .links em { font-style: normal; }

  .missing {
    padding: 24px;
    background: var(--pill-bg);
    border: 1px dashed var(--line);
    color: var(--muted);
    font-size: 13px;
  }
  .muted { color: var(--muted); }
</style>
